# Telegram bot token from @BotFather
BOT_TOKEN=

# fal.ai API key from https://fal.ai/dashboard/keys
FAL_KEY=

# Postgres connection string (Neon in production, e.g.
# postgresql://user:pass@ep-xxx-pooler.REGION.aws.neon.tech/db?sslmode=require).
# If unset, an embedded in-memory Postgres is used — fine for tests/local,
# but NOT persistent, so a real deployment MUST set this.
DATABASE_URL=

# 🔫 patrons (the in-app currency) granted to every new user on signup.
# 4 = exactly one Nano Banana 2 render (the free-trial model, best price/quality).
FREE_CREDITS=4

# --- Referral program (all optional; defaults shown) ---
# Extra patrons the INVITED friend gets on top of FREE_CREDITS when they join
# via a referral link (the only farmable surface — keep it small).
REFERRAL_JOIN_BONUS=3
# One-time patrons paid to the INVITER when their friend makes their 1st purchase.
REFERRAL_FIRST_PURCHASE_BONUS=10
# Lifetime share (0–1) of every pack a referred friend buys, paid to the inviter.
REFERRAL_PERCENT=0.1

# --- Partner program v2 (self-serve codes; docs/partner-program.md) ---
PARTNER_PERCENT=0.15          # cashback share of invitees' purchases (withdrawable)
PARTNER_WELCOME=180           # one-time join bonus 🔫 (spend-only, ≈$20)
PARTNER_INVITEE_BONUS=5       # 🔫 the invited user gets on top of FREE_CREDITS
PARTNER_MAX_CODES=10          # active codes per account
WITHDRAW_MIN=500              # minimum withdrawable 🔫 to request a cash-out

# Comma-separated Telegram user IDs with access to /stats, /funnel, /dash, /payouts, /orders
ADMIN_IDS=

# --- 48-hour re-engagement nudge (docs/growth-product.md) ---
# Once-daily sweep that DMs users who went dormant (>48h, but active within 14d),
# at most once each. Outbound messaging — set REENGAGE_ENABLED=false to disable.
REENGAGE_ENABLED=true
REENGAGE_HOUR_UTC=7      # 7 UTC = 10:00 МСК
REENGAGE_BATCH=50        # max users nudged per daily sweep

# --- Async generation reaper (docs/async-generation.md) ---
# Renders run detached (the bot never blocks). A generation still 'pending' beyond
# this many minutes is treated as a render whose process died, then failed +
# refunded (renders take 1–3 min).
GEN_STALE_MINUTES=15

# --- Identity-gate the free hook (docs/growth-product.md) ---
# Require a verified phone (Telegram contact) before the free scenario, and tie
# the gift to the PHONE — so multi-account farming needs multiple real numbers.
# OFF by default (adds onboarding friction); turn on when scaling PAID acquisition.
FREE_GATE_ENABLED=false

# --- Payments: Kaspi (KZT) — see docs/kaspi.md ---
# Kaspi payment link shown to buyers. Blank = buy flow records the order but tells
# the user payment isn't open yet. Set to go live.
KASPI_PAY_URL=https://pay.kaspi.kz/pay/1dwehs4t
# Optional per-pack FIXED-AMOUNT links — the way to "pre-fill the amount" without
# an unreliable ?amount= param: create one Kaspi link per pack and map it here.
# KASPI_PAY_URL_<PACKID> (COMBO/START/POPULAR/PRO/STUDIO); unset → falls back to
# KASPI_PAY_URL (the buyer then enters/confirms the amount).
KASPI_PAY_URL_COMBO=
KASPI_PAY_URL_START=
KASPI_PAY_URL_POPULAR=
KASPI_PAY_URL_PRO=
KASPI_PAY_URL_STUDIO=
# --- Kaspi auto-approval (merchant API) — removes the manual admin approve. ---
# Push: KASPI_API_SECRET enables the signed POST /api/kaspi/callback webhook
# (HMAC-SHA256 over the raw body). Blank → callback route disabled (404).
KASPI_API_SECRET=
KASPI_SIGNATURE_HEADER=x-kaspi-signature
# Pull: KASPI_API_BASE + KASPI_API_TOKEN let «Я оплатил» query the order's real
# status from Kaspi and auto-grant if paid. Blank → button pings an admin.
# ⚠️ Confirm the exact endpoint/signature/fields against Kaspi's merchant docs
# before enabling either path (docs/kaspi.md).
KASPI_API_BASE=
KASPI_API_TOKEN=
# ₸ per USD — digest gross-margin estimate only, never pricing.
KZT_PER_USD=480
# Launch combo offer window: sale ends COMBO_OFFER_DAYS after COMBO_OFFER_START
# (ISO date). Leave START blank for ~1 month from the server's boot.
COMBO_OFFER_DAYS=30
COMBO_OFFER_START=

# --- Telegram Mini App (web layer), optional ---
# Public HTTPS URL of the deployed Mini App. When set, the bot shows a
# "🌐 Приложение" button/menu and the app server starts. Also set the domain
# in @BotFather (Bot Settings → Configure Mini App).
WEBAPP_URL=
# Port the Mini App server listens on (behind your HTTPS reverse proxy)
WEBAPP_PORT=8080
# Bot username (without @) — used for the Mini App's "Пополнить" deep link
BOT_USERNAME=
# Domain Caddy provisions HTTPS for (docker-compose). Match WEBAPP_URL's host,
# e.g. WEBAPP_DOMAIN=app.example.com and WEBAPP_URL=https://app.example.com
WEBAPP_DOMAIN=
