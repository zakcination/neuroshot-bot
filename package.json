{
  "name": "neuroshot-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram GenAI photo/video bot: credits ledger, Telegram Stars payments, fal.ai model routing",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test scripts api",
    "check:patron": "node scripts/check-patron-emoji.mjs",
    "test:e2e": "tsx test/e2e.ts",
    "test:webapp": "tsx test/webapp.ts",
    "test": "npm run test:e2e && npm run test:webapp"
  },
  "engines": {
    "node": ">=19"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@fal-ai/client": "^1.5.0",
    "@neondatabase/serverless": "^1.1.0",
    "dotenv": "^16.4.5",
    "grammy": "^1.36.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^10.6.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.1"
  }
}
